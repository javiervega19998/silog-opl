rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // â”€â”€ Helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    function isAuth() {
      return request.auth != null;
    }
    function userEmail() {
      return request.auth.token.email;
    }
function userRol() {
      let uidPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let r = exists(uidPath) ? get(uidPath).data.rol : "conductor";
      return r != null ? r.lower() : "conductor";
    }

    // Admin + Administrativo + Administrativo.Conductor + Finanzas + Gestion
    function isViewer() {
      let r = userRol();
      return r != 'conductor' && r != 'bodeguero' && r != '';
    }
    // Bodeguero access
    function isBodeguero() {
      return userRol() in ['bodeguero', 'admin'];
    }
    // Can manage users (admin + administrativo)
    function canManageUsers() {
      return userRol() in ['admin', 'administrativo', 'administrativo.conductor'];
    }
    // Any valid role
    function isAnyRole() {
      let r = userRol();
      return r == 'admin' || r == 'administrativo' || r == 'administrativo.conductor' || r == 'conductor' || r == 'bodeguero' || r == 'finanzas' || r == 'gestion';
    }

    // â”€â”€ Usuarios â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    // Admin y Administrativo pueden crear/editar/eliminar usuarios; lectura solo para usuarios autenticados
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && (request.auth.uid == uid || canManageUsers());
      allow update: if isAuth() && (canManageUsers() || (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'roles', 'estado'])));
      allow delete: if isAuth() && canManageUsers();
    }

    // â”€â”€ Viajes â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /viajes/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.correo_conductor == userEmail());
      allow read:   if isAuth() && (isViewer() || resource.data.correo_conductor == userEmail());
      allow update, delete: if isAuth() && (isViewer() || resource.data.correo_conductor == userEmail());
    }

    // â”€â”€ Checklists â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /chequeo_operacional/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.operador == userEmail());
      allow read:   if isAuth() && (isViewer() || resource.data.operador == userEmail());
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Tareas â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /tareas/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.asignado_a == userEmail());
      allow read:   if isAuth() && (isViewer() || resource.data.asignado_a == userEmail());
      allow update: if isAuth() && (isViewer() || resource.data.asignado_a == userEmail());
      allow delete: if isAuth() && isViewer();
    }

    // â”€â”€ Charlas leÃ­das â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /charlas_leidas/{id} {
      allow create: if isAuth() && request.resource.data.operador == userEmail();
      allow read:   if isAuth() && (isViewer() || resource.data.operador == userEmail());
      allow update: if isAuth() && isViewer();
      allow delete: if isAuth() && isViewer();
    }

    // â”€â”€ Notificaciones â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /notificaciones/{id} {
      allow create: if isAuth();
      allow read: if isAuth();
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ VehÃ­culos â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    // Solo admin/administrativo puede crear/eliminar; conductores pueden actualizar km, estado y conductor
    match /vehiculos/{id} {
      allow read:  if isAuth();
      allow create, delete: if isAuth() && isViewer();
      allow update: if isAuth() && (
        isViewer() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'conductor', 'km', 'kilometraje']))
      );
    }

    // â”€â”€ KM Discrepancias â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /km_discrepancias/{id} {
      allow create: if isAuth();
      allow read:   if isAuth() && (isViewer() || resource.data.conductor_email == userEmail());
      allow update: if isAuth() && isViewer();
      allow delete: if isAuth() && isViewer();
    }

    // â”€â”€ Inventario â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    // Bodeguero + Viewer pueden escribir
    match /inventory/{id} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // â”€â”€ Correos / Formularios / Planillas â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /correos/{id}     { allow read, write: if isAuth() && isViewer(); }
    match /formularios/{id} { allow read, write: if isAuth() && isViewer(); }
    match /planillas/{id}   { allow read, write: if isAuth() && isViewer(); }

    // â”€â”€ Turnos (Apertura/Cierre de Jornada) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /turnos/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.conductor_uid == request.auth.uid);
      allow read:   if isAuth();
      allow update: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow delete: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
    }

    // â”€â”€ Despachos (Entregas por turno) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /despachos/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.conductor_uid == request.auth.uid);
      allow read:   if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow update: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow delete: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
    }

    // â”€â”€ Gastos en Ruta â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /gastos_ruta/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.conductor_uid == request.auth.uid);
      allow read:   if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow update, delete: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
    }

    // â”€â”€ Clientes (Directorio) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /clientes/{id} {
      allow read:  if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        isViewer() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coords', 'maps_url'])
      );
      allow delete: if isAuth() && isViewer();
    }

    // ── Logística Inversa (Devoluciones → Bodega) ──
    match /logistica_inversa/{id} {
      allow read, write: if isAuth() && isAnyRole();
    }

    // ── Movimientos de Bodega ──
    match /movimientos_bodega/{id} {
      allow read, write: if isAuth() && isAnyRole();
    }

    // ── Config Inversa (Logística Inversa) ──
    match /config_inversa/{id} {
      allow read:  if isAuth();
      allow write: if isAuth() && isViewer();
    }

    // â”€â”€ Productos (Stock extendido) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /productos/{id} {
      allow read:  if isAuth();
      allow write: if isAuth() && (isViewer() || isBodeguero());
    }

    // â”€â”€ Pre-Facturas (ERP Finanzas) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /prefacturas/{id} {
      allow read:  if isAuth() && isViewer();
      allow create: if isAuth() && (isViewer() || request.resource.data.creado_por == request.auth.uid);
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Hojas de Ruta (Finanzas + Conductor) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /hojas_ruta/{id} {
      allow create: if isAuth() && (isViewer() || request.resource.data.conductor_uid == request.auth.uid);
      allow read:   if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow update: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
      allow delete: if isAuth() && (isViewer() || resource.data.conductor_uid == request.auth.uid);
    }

    // â”€â”€ Ingresos Bodega (Finanzas) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /ingresos_bodega/{id} {
      allow read:  if isAuth() && isViewer();
      allow create: if isAuth() && isViewer();
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Gastos Contabilidad (Manual ERP Finanzas) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /gastos_contabilidad/{id} {
      allow read:  if isAuth() && isViewer();
      allow create: if isAuth() && isViewer();
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Servicios Especiales (Manual ERP Finanzas) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /servicios_especiales/{id} {
      allow read:  if isAuth() && isViewer();
      allow create: if isAuth() && isViewer();
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Distribuidores (Lista dinÃ¡mica) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /distribuidores/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && isViewer();
    }

    // â”€â”€ Recordatorios (Kanban Admin) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /recordatorios/{id} {
      allow create: if isAuth() && isViewer();
      allow read:   if isAuth() && isViewer();
      allow update: if isAuth() && isViewer();
      allow delete: if isAuth() && isViewer();
    }

    // ── Registro de Auditoría ──────────────────────────────────────
    match /audit_log/{id} {
      allow create: if isAuth();
      allow read: if isAuth() && isViewer();
      allow update, delete: if false;
    }
  }
}
